{
  "name": "@tokenpilot/api",
  "version": "0.2.0",
  "private": true,
  "description": "NestJS Fastify API for TokenPilot",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test:integration": "vitest run --configLoader runner test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tokenpilot/clickhouse": "workspace:*",
    "@tokenpilot/contracts": "workspace:*",
    "@tokenpilot/db": "workspace:*",
    "@tokenpilot/reconciliation-engine": "workspace:*",
    "@tokenpilot/shared": "workspace:*",
    "@tokenpilot/user-segmentation": "workspace:*",
    "@fastify/static": "9.3.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "bullmq": "5.80.2",
    "fastify": "5.10.0",
    "ioredis": "5.10.1",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "secure-json-parse": "4.1.0",
    "ulid": "3.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/pg": "8.18.0",
    "pg": "8.22.0"
  }
}
