{
  "name": "@tokenpilot/worker",
  "version": "0.2.0",
  "private": true,
  "description": "BullMQ workers for normalized usage processing",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test:integration": "vitest run --configLoader runner test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tokenpilot/clickhouse": "workspace:*",
    "@tokenpilot/contracts": "workspace:*",
    "@tokenpilot/db": "workspace:*",
    "@tokenpilot/reconciliation-engine": "workspace:*",
    "@tokenpilot/shared": "workspace:*",
    "@tokenpilot/usage-normalizer": "workspace:*",
    "@tokenpilot/user-segmentation": "workspace:*",
    "bullmq": "5.80.2",
    "ioredis": "5.10.1",
    "prom-client": "15.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/pg": "8.18.0",
    "pg": "8.22.0"
  }
}
