# TokenPilot application keys. Create these inside the target application.
AI_CONTROL_URL=http://127.0.0.1:8080
AI_CONTROL_API_KEY=replace-with-usage-and-heartbeat-key
AI_CONTROL_POLICY_API_KEY=replace-with-runtime-key
TOKENPILOT_VERIFY_API_KEY=replace-with-reports-read-key
TOKENPILOT_APPLICATION_SLUG=my-application

# Native local runtime. No Docker, Podman, Lima, or Colima is used.
AI_CONTROL_CONNECTOR_INSTANCE_ID=mac-litellm-local
AI_CONTROL_SPOOL_PATH=.tokenpilot/litellm-local-spool.sqlite3
AI_CONTROL_POLICY_LKG_PATH=.tokenpilot/litellm-local-runtime.json
AI_CONTROL_FLUSH_INTERVAL_SECONDS=0.2
AI_CONTROL_HEARTBEAT_INTERVAL_SECONDS=5
AI_CONTROL_POLICY_POLL_INTERVAL_SECONDS=5
AI_CONTROL_POLICY_REQUIRED=false
AI_CONTROL_QUOTA_ENABLED=false
TOKENPILOT_RUN_EVIDENCE=.tokenpilot/litellm-local-run.json

# The fake Provider is the zero-secret default. Set false and choose any LiteLLM model tags below
# to use OpenAI, Anthropic, Gemini, or another LiteLLM-supported Provider.
TOKENPILOT_USE_FAKE_PROVIDER=true
LITELLM_SUCCESS_MODEL=openai/local-success
LITELLM_PRIMARY_MODEL=openai/local-primary
LITELLM_FALLBACK_MODEL=openai/local-fallback

# Optional proxy for dependency/model access. localhost is always bypassed.
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
NO_PROXY=127.0.0.1,localhost

# Optional for a real OpenAI-compatible endpoint. For native Providers, use their standard key
# variable instead, such as OPENAI_API_KEY or ANTHROPIC_API_KEY.
# LITELLM_API_BASE=https://your-provider.example/v1
# LITELLM_API_KEY=replace-with-provider-key
