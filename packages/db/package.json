{
  "name": "@tokenpilot/db",
  "version": "0.2.0",
  "private": true,
  "description": "Prisma schema, migrations, and database access for TokenPilot",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "pnpm clean && prisma generate && tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "feature-flags": "tsx src/feature-flags-cli.ts",
    "generate": "prisma generate",
    "test:integration": "vitest run --configLoader runner test/current-schema.integration.test.ts",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tokenpilot/shared": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "better-auth": "1.6.23",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.18.0",
    "dotenv": "17.2.3",
    "prisma": "7.8.0"
  }
}
