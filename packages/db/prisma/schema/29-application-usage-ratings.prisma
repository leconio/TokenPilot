model ApplicationUsageRating {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String             @map("application_id") @db.Uuid
  eventId       String             @map("event_id") @db.VarChar(36)
  userId        String             @map("user_id") @db.Uuid
  modelId       String             @map("model_id") @db.Uuid
  virtualModel  String?            @map("virtual_model") @db.VarChar(120)
  costStatus    String             @map("cost_status") @db.VarChar(32)
  providerCost  Decimal?           @map("provider_cost") @db.Decimal(38, 18)
  currency      String?            @db.Char(3)
  costVersionId String?            @map("cost_version_id") @db.Uuid
  costLinesJson Json               @default("[]") @map("cost_lines_json")
  inputTokens   Decimal            @default(0) @map("input_tokens") @db.Decimal(38, 9)
  outputTokens  Decimal            @default(0) @map("output_tokens") @db.Decimal(38, 9)
  cachedTokens  Decimal            @default(0) @map("cached_tokens") @db.Decimal(38, 9)
  totalTokens   Decimal            @default(0) @map("total_tokens") @db.Decimal(38, 9)
  aiuStatus     String             @map("aiu_status") @db.VarChar(32)
  aiuMicros     BigInt?            @map("aiu_micros")
  aiuVersionId  String?            @map("aiu_version_id") @db.Uuid
  aiuLinesJson  Json               @default("[]") @map("aiu_lines_json")
  ratedAt       DateTime           @default(now()) @map("rated_at") @db.Timestamptz(6)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  event         UsageEventRegistry @relation(fields: [applicationId, eventId], references: [applicationId, eventId], onDelete: Restrict)
  user          ApplicationUser    @relation(fields: [applicationId, userId], references: [applicationId, id], onDelete: Restrict)
  model         ModelDefinition    @relation(fields: [applicationId, modelId], references: [applicationId, id], onDelete: Restrict)

  @@unique([applicationId, eventId], map: "application_usage_ratings_event_key")
  @@index([applicationId, userId, ratedAt], map: "application_usage_ratings_user_idx")
  @@index([applicationId, modelId, ratedAt], map: "application_usage_ratings_model_idx")
  @@index([applicationId, virtualModel, ratedAt], map: "application_usage_ratings_virtual_idx")
  @@map("application_usage_ratings")
}
