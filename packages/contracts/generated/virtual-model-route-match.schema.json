{
  "$id": "https://tokenpilot.dev/schemas/virtual-model-route-match.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "override_active": {
              "type": "boolean",
              "const": true
            }
          },
          "required": [
            "override_active"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "schedule": {
              "type": "object",
              "properties": {
                "days": {
                  "minItems": 1,
                  "maxItems": 7,
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/__schema0"
                  }
                },
                "from": {
                  "$ref": "#/$defs/__schema1"
                },
                "to": {
                  "$ref": "#/$defs/__schema1"
                }
              },
              "required": [
                "days",
                "from",
                "to"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "schedule"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "user": {
              "type": "object",
              "properties": {
                "ids": {
                  "maxItems": 50000,
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/__schema2"
                  }
                }
              },
              "required": [
                "ids"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "user"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "user_property": {
              "type": "object",
              "properties": {
                "key": {
                  "$ref": "#/$defs/__schema3"
                },
                "operator": {
                  "$ref": "#/$defs/__schema4"
                },
                "value": {
                  "$ref": "#/$defs/__schema5"
                }
              },
              "required": [
                "key",
                "operator"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "user_property"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "call_source": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                }
              },
              "required": [
                "value"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "call_source"
          ],
          "additionalProperties": false
        }
      ]
    },
    {
      "type": "object",
      "properties": {
        "user_group": {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
          "required": [
            "group_id"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "user_group"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "user_tag": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "user_tag"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "aiu_state": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "enum": [
                "available",
                "low",
                "exhausted",
                "unlimited"
              ]
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "aiu_state"
      ],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "__schema0": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },
    "__schema1": {
      "type": "string",
      "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$"
    },
    "__schema2": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "__schema3": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,127}$"
    },
    "__schema4": {
      "type": "string",
      "enum": [
        "equals",
        "not_equals",
        "contains",
        "starts_with",
        "is_set",
        "is_not_set"
      ]
    },
    "__schema5": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 2048
        },
        {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        {
          "type": "boolean"
        }
      ]
    }
  }
}
