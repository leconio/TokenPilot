{
  "$id": "https://tokenpilot.dev/schemas/runtime-configuration-acknowledgement.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/__schema0"
    },
    "application_id": {
      "$ref": "#/$defs/__schema1"
    },
    "acknowledgement_id": {
      "$ref": "#/$defs/__schema2"
    },
    "acknowledged_at": {
      "$ref": "#/$defs/__schema3"
    },
    "connector": {
      "$ref": "#/$defs/__schema4"
    },
    "configuration_version": {
      "$ref": "#/$defs/__schema5"
    },
    "configuration_etag": {
      "$ref": "#/$defs/__schema6"
    },
    "state": {
      "$ref": "#/$defs/__schema7"
    },
    "applied_at": {
      "$ref": "#/$defs/__schema8"
    },
    "error": {
      "$ref": "#/$defs/__schema9"
    }
  },
  "required": [
    "schema_version",
    "application_id",
    "acknowledgement_id",
    "acknowledged_at",
    "connector",
    "configuration_version",
    "configuration_etag",
    "state",
    "applied_at",
    "error"
  ],
  "additionalProperties": false,
  "title": "Runtime Configuration Acknowledgement",
  "description": "A connector reports whether an application runtime configuration was received, applied, or rejected.",
  "$defs": {
    "__schema0": {
      "type": "string",
      "const": "2.0"
    },
    "__schema1": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "__schema2": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        }
      ]
    },
    "__schema3": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
    },
    "__schema4": {
      "type": "object",
      "properties": {
        "instance_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "name": {
          "type": "string",
          "enum": [
            "node",
            "python",
            "litellm"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
        }
      },
      "required": [
        "instance_id",
        "name",
        "version"
      ],
      "additionalProperties": false
    },
    "__schema5": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "__schema6": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "__schema7": {
      "type": "string",
      "enum": [
        "received",
        "applied",
        "rejected"
      ]
    },
    "__schema8": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema9": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "maxLength": 120,
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "message": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          },
          "required": [
            "code",
            "message"
          ],
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
