{
  "$id": "https://tokenpilot.dev/schemas/reconciliation-run.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "application_id": {
      "$ref": "#/$defs/__schema0"
    },
    "run_type": {
      "$ref": "#/$defs/ReconciliationRunType"
    },
    "range_start": {
      "$ref": "#/$defs/__schema1"
    },
    "range_end": {
      "$ref": "#/$defs/__schema1"
    },
    "status": {
      "$ref": "#/$defs/ReconciliationRunStatus"
    },
    "pg_watermark": {
      "$ref": "#/$defs/__schema2"
    },
    "ch_watermark": {
      "$ref": "#/$defs/__schema3"
    },
    "summary": {
      "$ref": "#/$defs/ReconciliationRunSummary"
    },
    "started_by": {
      "$ref": "#/$defs/__schema4"
    },
    "started_at": {
      "$ref": "#/$defs/__schema1"
    },
    "finished_at": {
      "$ref": "#/$defs/__schema5"
    },
    "error": {
      "$ref": "#/$defs/__schema6"
    }
  },
  "required": [
    "id",
    "application_id",
    "run_type",
    "range_start",
    "range_end",
    "status",
    "pg_watermark",
    "ch_watermark",
    "summary",
    "started_by",
    "started_at",
    "finished_at",
    "error"
  ],
  "additionalProperties": false,
  "title": "Reconciliation Run",
  "description": "A bounded comparison of PostgreSQL official and ClickHouse projected data.",
  "$defs": {
    "__schema0": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,255}$"
    },
    "ReconciliationRunType": {
      "type": "string",
      "enum": [
        "hourly",
        "daily",
        "manual",
        "rebuild",
        "unknown"
      ]
    },
    "__schema1": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
    },
    "ReconciliationRunStatus": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled",
        "unknown"
      ]
    },
    "__schema2": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema3": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "type": "null"
        }
      ]
    },
    "ReconciliationRunSummary": {
      "type": "object",
      "properties": {
        "event_count": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "input_tokens": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "cached_input_tokens": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "output_tokens": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "provider_cost": {
          "$ref": "#/$defs/Decimal38Scale18"
        },
        "aiu_micros": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "unpriced_count": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "unrated_count": {
          "$ref": "#/$defs/MicroAiuString"
        },
        "diff_count": {
          "$ref": "#/$defs/MicroAiuString"
        }
      },
      "required": [
        "event_count",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "provider_cost",
        "aiu_micros",
        "unpriced_count",
        "unrated_count",
        "diff_count"
      ],
      "additionalProperties": false
    },
    "MicroAiuString": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,18})$",
      "format": "nonnegative-int64-string",
      "description": "A canonical decimal string in the non-negative signed-int64 range."
    },
    "Decimal38Scale18": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,19})(?:\\.[0-9]{1,18})?$"
    },
    "__schema4": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema0"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema5": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema6": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
