    "__schema8": {
      "type": "string",
      "enum": [
        "equals",
        "not_equals",
        "contains",
        "starts_with",
        "greater_than",
        "greater_or_equal",
        "less_than",
        "less_or_equal",
        "between",
        "one_of",
        "contains_any",
        "contains_all",
        "is_set",
        "is_not_set"
      ]
    },
    "__schema9": {
      "maxItems": 32,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema10"
      }
    },
    "__schema10": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        {
          "type": "boolean"
        }
      ]
    },
    "__schema11": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "property"
        },
        "scope": {
          "type": "string",
          "enum": [
            "event",
            "user"
          ]
        },
        "key": {
          "$ref": "#/$defs/__schema12"
        },
        "operator": {
          "$ref": "#/$defs/__schema8"
        },
        "values": {
          "default": [],
          "$ref": "#/$defs/__schema9"
        }
      },
      "required": [
        "kind",
        "scope",
        "key",
        "operator",
        "values"
      ],
      "additionalProperties": false
    },
    "__schema12": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,127}$"
    },
    "__schema13": {
      "default": "requests",
      "type": "string",
      "enum": [
        "requests",
        "tokens",
        "unique_users",
        "success_rate",
        "average_latency",
        "provider_cost",
        "aiu"
      ]
    },
    "__schema14": {
      "default": "day",
      "type": "string",
      "enum": [
        "hour",
        "day",
        "week",
        "month"
      ]
    },
    "__schema15": {
      "default": "request_model",
      "type": "string",
      "enum": [
        "model_id",
        "request_model",
        "virtual_model",
        "connection_id",
        "connection_driver",
        "user_id",
        "user_tag",
        "provider",
        "route_reason",
        "time",
        "hour",
        "day",
        "week",
        "month",
        "property"
      ]
    },
    "__schema16": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "event",
            "user"
          ]
        },
        "key": {
          "$ref": "#/$defs/__schema12"
        }
      },
      "required": [
        "scope",
        "key"
      ],
      "additionalProperties": false
    }
  }
