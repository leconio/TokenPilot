            "user_id",
            "display_user",
            "user_tag",
            "user_group",
            "application_version",
            "sdk_version",
            "connector_version",
            "config_version",
            "virtual_model",
            "model_id",
            "connection_id",
            "connection_driver",
            "request_model",
            "provider",
            "status",
            "schema_version",
            "route_reason",
            "latency_ms",
            "cost_status",
            "aiu_status",
            "quota_status"
