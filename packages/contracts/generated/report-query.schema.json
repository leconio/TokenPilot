      "$ref": "#/$defs/__schema1"
    },
    "cursor": {
      "$ref": "#/$defs/__schema2"
    },
    "page_size": {
      "$ref": "#/$defs/__schema3"
    },
    "filter_match": {
      "$ref": "#/$defs/__schema4"
    },
    "conditions": {
      "$ref": "#/$defs/__schema5"
    },
    "metric": {
      "$ref": "#/$defs/__schema13"
    },
    "grain": {
      "$ref": "#/$defs/__schema14"
    },
    "group_dimension": {
