{
  "$id": "https://tokenpilot.dev/schemas/report-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "watermark": {
      "$ref": "#/$defs/__schema0"
    },
    "lag_seconds": {
      "$ref": "#/$defs/__schema2"
    },
    "range": {
      "$ref": "#/$defs/__schema3"
    },
    "data": {
      "$ref": "#/$defs/__schema5"
    }
  },
  "required": [
    "watermark",
    "lag_seconds",
    "range",
    "data"
  ],
  "additionalProperties": false,
  "title": "Report Envelope",
  "description": "Analytics result with a ClickHouse watermark and projection lag.",
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema1": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
    },
    "__schema2": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema3": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReportRange"
        },
        {
          "type": "null"
        }
      ]
    },
    "ReportRange": {
      "type": "object",
      "properties": {
        "from": {
          "$ref": "#/$defs/__schema1"
        },
        "to": {
          "$ref": "#/$defs/__schema1"
        },
        "timezone": {
          "$ref": "#/$defs/__schema4"
        }
      },
      "required": [
        "from",
        "to",
        "timezone"
      ],
      "additionalProperties": false
    },
    "__schema4": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "__schema5": {}
  }
}
