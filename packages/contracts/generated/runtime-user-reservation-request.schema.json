{
  "$id": "https://tokenpilot.dev/schemas/runtime-user-reservation-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "display_user": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "user_properties": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9._-]{0,127}$"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "maxLength": 2048
          },
          {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          {
            "type": "boolean"
          },
          {
            "maxItems": 32,
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          }
        ]
      }
    },
    "operation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,255}$"
    },
    "virtual_model": {
      "type": "string",
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "candidate_model_ids": {
      "minItems": 1,
      "maxItems": 32,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema1"
      }
    },
    "estimated_aiu_micros": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)$"
    }
  },
  "required": [
    "user_id",
    "operation_id",
    "virtual_model",
    "estimated_aiu_micros"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "maxLength": 256
    },
    "__schema1": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    }
  }
}
