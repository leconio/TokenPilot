# TokenPilot instance
INSTANCE_ID=tokenpilot-local-01
ENVIRONMENT=development
APP_TIMEZONE=Asia/Shanghai
BASE_CURRENCY=USD

# PostgreSQL and Redis
POSTGRES_DB=tokenpilot
POSTGRES_USER=tokenpilot
POSTGRES_PASSWORD=replace-with-generated-secret
DATABASE_URL=postgresql://tokenpilot:replace-with-generated-secret@postgres:5432/tokenpilot
REDIS_URL=redis://redis:6379

# Web and API security
WEB_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
# Keep false only for direct trusted HTTP. Set true behind an HTTPS gateway.
WEB_SESSION_COOKIE_SECURE=false
API_KEY_PEPPER=replace-with-generated-secret
# Privacy: TokenPilot never needs prompt or response content.
STORE_PROMPT_CONTENT=false
STORE_RESPONSE_CONTENT=false

# Features used by a new installation.
FEATURE_USAGE_PIPELINE=true
FEATURE_MODEL_CATALOG=true
FEATURE_AIU=true
FEATURE_QUOTA=true
FEATURE_HARD_LIMIT=false
FEATURE_RECONCILIATION=true

# ClickHouse
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=tokenpilot
CLICKHOUSE_BOOTSTRAP_PASSWORD=replace-with-generated-secret
CLICKHOUSE_MIGRATION_USERNAME=tokenpilot_migrator
CLICKHOUSE_MIGRATION_PASSWORD=replace-with-generated-secret
CLICKHOUSE_USERNAME=tokenpilot_app
CLICKHOUSE_PASSWORD=replace-with-generated-secret
CLICKHOUSE_SECURE=false
CLICKHOUSE_REQUEST_TIMEOUT_MS=10000
CLICKHOUSE_INSERT_BATCH_SIZE=1000
CLICKHOUSE_INSERT_FLUSH_MS=1000
CLICKHOUSE_ASYNC_INSERT=true
CLICKHOUSE_WAIT_FOR_ASYNC_INSERT=true
CLICKHOUSE_RAW_RETENTION_DAYS=90
CLICKHOUSE_LINES_RETENTION_DAYS=180
CLICKHOUSE_MINUTE_RETENTION_DAYS=90
CLICKHOUSE_HOURLY_RETENTION_DAYS=730
CLICKHOUSE_DAILY_RETENTION_DAYS=1825
CLICKHOUSE_FRESH_REBUILD_ALLOWED=false
CLICKHOUSE_FRESH_REBUILD_OWNER=

# AI Unit defaults. Start in measurement mode; enable hard limits only after
# prices and user quotas have been reviewed in the Web console.
AIU_ENABLED=true
AIU_MODE=observe
AIU_SYMBOL=AIU
AIU_MICRO_SCALE=1000000
AIU_UNRATED_MODEL_POLICY=allow_unrated
AIU_ATTEMPT_CHARGE_POLICY=final_success_only
AIU_DEFAULT_ROUNDING=half_up
AIU_RESERVATION_SIGNING_KEY=replace-with-generated-secret
AIU_RESERVATION_KEY_VERSION=current
AIU_RESERVATION_TTL_SECONDS=300

# Usage processing and reconciliation
DIMENSION_MAX_KEYS=32
DIMENSION_MAX_KEY_LENGTH=64
DIMENSION_MAX_VALUE_LENGTH=256
DIMENSION_MAX_TOTAL_BYTES=8192
DIMENSION_UNKNOWN_KEY_POLICY=drop_and_record
INBOX_PAYLOAD_RETENTION_DAYS=14
INBOX_PAYLOAD_CLEANUP_INTERVAL_MS=300000
INBOX_PAYLOAD_CLEANUP_BATCH_SIZE=500
AIU_RESERVATION_SWEEP_INTERVAL_MS=30000
AIU_RESERVATION_SWEEP_BATCH_SIZE=100
CH_SINK_MAX_RETRIES=20
PIPELINE_POLL_INTERVAL_MS=250
CLICKHOUSE_OUTBOX_POLL_INTERVAL_MS=500
RECONCILIATION_HOURLY_ENABLED=true
RECONCILIATION_DAILY_ENABLED=true
RECONCILIATION_USER_HMAC_SECRET=replace-with-generated-secret
RECON_COST_TOLERANCE=0.000001
RECON_AIU_MICRO_TOLERANCE=0
RAW_EVENT_RETENTION_DAYS=90

# Runtime limits and ingress
API_PORT=4000
LOG_LEVEL=info
INGEST_MAX_BATCH_SIZE=500
INGEST_MAX_COMPRESSED_BYTES=1048576
INGEST_MAX_DECOMPRESSED_BYTES=5242880
API_REQUEST_TIMEOUT_MS=10000
API_RATE_LIMIT_MAX=600
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
CONNECTOR_STALE_AFTER_SECONDS=120
CONNECTOR_BACKLOG_ALERT_DEPTH=1000
CONTROL_PLANE_VERSION=0.2.0
CADDY_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080
# Only used with deploy/docker-compose.external-gateway.yml.
EXTERNAL_GATEWAY_API_BIND_ADDRESS=127.0.0.1
EXTERNAL_GATEWAY_API_PORT=15001
EXTERNAL_GATEWAY_WEB_BIND_ADDRESS=127.0.0.1
EXTERNAL_GATEWAY_WEB_PORT=15002
