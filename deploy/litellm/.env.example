# Control Plane service credential (not a model Provider credential).
AI_CONTROL_URL=http://api:4000
AI_CONTROL_API_KEY=replace-with-control-plane-ingestion-key
AI_CONTROL_POLICY_API_KEY=replace-with-control-plane-policy-key
AI_CONTROL_CONNECTOR_INSTANCE_ID=litellm-production-01
AI_CONTROL_SPOOL_PATH=/var/lib/tokenpilot/litellm-spool.sqlite3
AI_CONTROL_MAX_SPOOL_BYTES=536870912
AI_CONTROL_BATCH_SIZE=100
AI_CONTROL_FLUSH_INTERVAL_SECONDS=1
AI_CONTROL_RETRY_BASE_SECONDS=1
AI_CONTROL_RETRY_MAX_SECONDS=300
AI_CONTROL_HEARTBEAT_INTERVAL_SECONDS=30

# Provider credentials stay only in the LiteLLM secret environment. These are
# placeholders and must never be copied into Control Plane metadata.
OPENAI_API_KEY=replace-in-litellm-secret-environment
AZURE_OPENAI_API_KEY=replace-in-litellm-secret-environment
AZURE_OPENAI_ENDPOINT=https://replace-with-your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=replace-with-supported-api-version
GEMINI_API_KEY=replace-in-litellm-secret-environment
