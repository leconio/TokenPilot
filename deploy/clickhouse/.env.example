# Copy this file outside the repository and replace every placeholder with an
# independently generated secret. Do not commit populated values.
CLICKHOUSE_BOOTSTRAP_PASSWORD=<generated-bootstrap-secret>

# Runtime identity: data reads/writes only; never use `default` here.
CLICKHOUSE_USERNAME=ai_control_app
CLICKHOUSE_PASSWORD=<generated-application-secret>

# Schema migration identity: DDL only within CLICKHOUSE_DATABASE.
CLICKHOUSE_MIGRATION_USERNAME=ai_control_migrator
CLICKHOUSE_MIGRATION_PASSWORD=<generated-migration-secret>

CLICKHOUSE_DATABASE=ai_control_plane
